# Plugin opt-in flags. Each plugin is wrapped in a dynamic import that
# only runs when its flag is "1". Vite tree-shakes the plugin chunk
# from the user's network when the flag is absent.

# Sync plugin — cross-device sync over the @ollu SDK.
# VITE_OLLU_SYNC=1

# Backup plugin — export/import the local library to a JSON file.
# VITE_OLLU_BACKUP=1

# Appearance plugin — theme (light/dark/auto) + font choice; persists
# to localStorage of the current browser.
# VITE_OLLU_APPEARANCE=1

# Language plugin — manual UI language override (English / Русский).
# Without it the language follows the system (navigator.languages).
# The choice persists to localStorage of the current browser.
# VITE_OLLU_LANG=1

# Predict plugin — offline inline autocomplete (ghost-text). Learns a
# per-language n-gram model from your writing into a local IndexedDB; no
# model download, works offline. Tab (or click) accepts the suggestion.
# VITE_OLLU_PREDICT=1
#
# Tier 1 (optional, English only): on WebGPU devices the user can explicitly
# download a small on-device LM (in Autocomplete settings) for whole-phrase
# suggestions. Default is distilgpt2 in int8 (~80 MB). Russian always uses the
# offline word completion (Tier 0). Override the model/quantisation here.
# VITE_OLLU_PREDICT_MODEL=Xenova/distilgpt2
# VITE_OLLU_PREDICT_DTYPE=q8

# Voice plugin — on-device voice typing (dictation). Press and hold a
# trigger key (default Ctrl) to dictate; interim text shows as a live ghost
# preview and is inserted at the caret on release. Recognition runs fully
# on-device via Whisper (transformers.js + WebGPU); audio never leaves the
# browser. The model is an explicit, opt-in download from settings.
# VITE_OLLU_VOICE=1
#
# The user picks the model in settings (Tiny / Base / Small — all multilingual
# ru+en); bigger is more accurate for Russian but a heavier download and slower
# per interim tick. VITE_OLLU_VOICE_MODEL only sets the *default* selection
# (must be one of the catalog ids, or a custom HF id). DTYPE is the quantisation
# applied to whichever model is loaded.
# VITE_OLLU_VOICE_MODEL=Xenova/whisper-tiny
# VITE_OLLU_VOICE_DTYPE=q8

# Ollu sync server URL (overridable per-user in Settings).
# Only meaningful when VITE_OLLU_SYNC=1. Defaults to http://localhost:8080.
# VITE_OLLU_SERVER=https://api.ollu.example.com

# Google OAuth client ID for PKCE login. Get one from
# https://console.cloud.google.com/apis/credentials — register an
# OAuth 2.0 Client ID of type "Web application" and add this app's
# origin (plus http://localhost:5173) to authorised origins/redirect URIs.
# Leave empty to disable Google auth (sync stays offline-only).
# VITE_OLLU_GOOGLE_CLIENT_ID=
