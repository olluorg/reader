# Plugin opt-in flags. Each plugin is wrapped in a dynamic import that
# only runs when its flag is "1". Vite tree-shakes the plugin chunk
# from the user's network when the flag is absent.

# Sync plugin — cross-device sync over the @ollu SDK.
# VITE_OLLU_SYNC=1

# Backup plugin — export/import the local library to a JSON file.
# VITE_OLLU_BACKUP=1

# Appearance plugin — theme (light/dark/auto) + font choice; persists
# to localStorage of the current browser.
# VITE_OLLU_APPEARANCE=1

# Language plugin — manual UI language override (English / Русский).
# Without it the language follows the system (navigator.languages).
# The choice persists to localStorage of the current browser.
# VITE_OLLU_LANG=1

# Ollu sync server URL (overridable per-user in Settings).
# Only meaningful when VITE_OLLU_SYNC=1. Defaults to http://localhost:8080.
# VITE_OLLU_SERVER=https://api.ollu.example.com

# Google OAuth client ID for PKCE login. Get one from
# https://console.cloud.google.com/apis/credentials — register an
# OAuth 2.0 Client ID of type "Web application" and add this app's
# origin (plus http://localhost:5173) to authorised origins/redirect URIs.
# Leave empty to disable Google auth (sync stays offline-only).
# VITE_OLLU_GOOGLE_CLIENT_ID=
