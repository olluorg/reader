# Ollu sync server URL (overridable per-user in Settings).
# Leave commented out to default to http://localhost:8080 in dev.
# VITE_OLLU_SERVER=https://api.ollu.example.com

# Google OAuth client ID for PKCE login. Get one from
# https://console.cloud.google.com/apis/credentials — register an
# OAuth 2.0 Client ID of type "Web application" and add this app's
# origin (plus http://localhost:5173) to authorised origins/redirect URIs.
# Leave empty to disable Google auth (sync stays offline-only).
# VITE_OLLU_GOOGLE_CLIENT_ID=
